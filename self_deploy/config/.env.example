# ==============================
# Champion Council Self-Deploy
# ==============================

# Runtime
APP_ENV=development
APP_PORT=7866
MCP_PORT=8766
CAPSULE_PATH=./capsule/champion_gen8.py
CAPSULE_GZ_PATH=./capsule/capsule.gz
# Optional read-only fallback gzip path (used before remote download)
CAPSULE_BOOTSTRAP_GZ_PATH=../capsule/capsule.gz
# Used when capsule files are missing locally (self_deploy-only download)
CAPSULE_DOWNLOAD_URL=https://huggingface.co/spaces/tostido/Champion_Council/resolve/main/capsule/capsule.gz
MANAGE_LOCAL_CAPSULE=1

# Optional external MCP URL (if using a remote capsule instead of local process)
# MCP_BASE_URL=http://127.0.0.1:8766

# Persistence
# local = filesystem only
# hf    = HF dataset repo only
# both  = local + HF sync
PERSISTENCE_MODE=local
DATA_DIR=./data
AUTOSAVE_INTERVAL=300
SAVE_COOLDOWN=120

# Hugging Face
HF_TOKEN=
SPACE_AUTHOR_NAME=
SPACE_ID=

# Vast.ai
VAST_API_KEY=
# Optional: provide pre-generated SSH keypair for Vast tools
SSH_PRIVATE_KEY=
SSH_PUBLIC_KEY=

# Search Providers
BRAVE_API_KEY=
SERPER_API_KEY=
GOOGLE_API_KEY=

# LLM Providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# IPFS Providers (optional)
PINATA_JWT=
WEB3_STORAGE_TOKEN=

# Nostr (optional)
NOSTR_PRIVATE_KEY=
NOSTR_RELAY_URL=

# Logging/Telemetry
LOG_LEVEL=INFO
ACTIVITY_LOG_MAX=500
