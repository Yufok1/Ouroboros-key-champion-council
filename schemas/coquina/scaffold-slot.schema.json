{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://champion-council.local/schemas/coquina/scaffold-slot.schema.json",
  "title": "Champion Council Coquina Scaffold Slot Record",
  "type": "object",
  "required": [
    "family",
    "slot",
    "joint",
    "geometry",
    "default_scale",
    "parametric_ranges",
    "surface_classes",
    "region_class",
    "authoring_anchor"
  ],
  "properties": {
    "family": {
      "type": "string",
      "minLength": 1
    },
    "slot": {
      "type": "string",
      "minLength": 1
    },
    "joint": {
      "type": "string",
      "minLength": 1
    },
    "geometry": {
      "type": "string",
      "enum": [
        "ellipsoid",
        "limb"
      ]
    },
    "default_scale": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number"
      }
    },
    "parametric_ranges": {
      "type": "object",
      "required": [
        "scale_x",
        "scale_y",
        "scale_z"
      ],
      "properties": {
        "scale_x": {
          "$ref": "#/$defs/rangeTuple"
        },
        "scale_y": {
          "$ref": "#/$defs/rangeTuple"
        },
        "scale_z": {
          "$ref": "#/$defs/rangeTuple"
        }
      },
      "additionalProperties": false
    },
    "surface_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "region_class": {
      "type": "string",
      "minLength": 1
    },
    "authoring_anchor": {
      "type": "boolean"
    },
    "target_joint": {
      "type": "string",
      "minLength": 1
    },
    "follow_child": {
      "type": "boolean"
    },
    "project_from_parent": {
      "type": "boolean"
    },
    "axis": {
      "type": "string",
      "minLength": 1
    },
    "up_offset": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number"
      }
    },
    "color": {
      "type": "integer"
    }
  },
  "$defs": {
    "rangeTuple": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number"
      }
    }
  },
  "additionalProperties": false
}
