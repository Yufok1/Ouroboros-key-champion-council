{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://champion-council.local/schemas/coquina/palette-checkpoint.schema.json",
  "title": "Champion Council Coquina Palette Checkpoint Record",
  "type": "object",
  "required": [
    "checkpoint_id",
    "scene_id",
    "seed_palette"
  ],
  "properties": {
    "checkpoint_id": {
      "type": "string",
      "minLength": 1
    },
    "scene_id": {
      "type": "string",
      "minLength": 1
    },
    "seed_palette": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/oklchRole"
      }
    },
    "applied_transforms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "delta_L": {
            "type": "number"
          },
          "delta_C": {
            "type": "number"
          },
          "delta_H": {
            "type": "number"
          }
        },
        "anyOf": [
          {
            "required": [
              "delta_L"
            ]
          },
          {
            "required": [
              "delta_C"
            ]
          },
          {
            "required": [
              "delta_H"
            ]
          }
        ],
        "additionalProperties": false
      }
    },
    "per_surface_class_bindings": {
      "type": "object",
      "patternProperties": {
        "^[^:]+:[^:]+:[^:]+$": {
          "type": "object",
          "required": [
            "base_oklch",
            "micro_variance"
          ],
          "properties": {
            "base_oklch": {
              "$ref": "#/$defs/oklch"
            },
            "micro_variance": {
              "type": "object",
              "required": [
                "delta_L",
                "delta_C",
                "delta_H"
              ],
              "properties": {
                "delta_L": {
                  "$ref": "#/$defs/range"
                },
                "delta_C": {
                  "$ref": "#/$defs/range"
                },
                "delta_H": {
                  "$ref": "#/$defs/range"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "oklch": {
      "type": "object",
      "required": [
        "L",
        "C",
        "H"
      ],
      "properties": {
        "L": {
          "type": "number"
        },
        "C": {
          "type": "number"
        },
        "H": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "oklchRole": {
      "allOf": [
        {
          "$ref": "#/$defs/oklch"
        },
        {
          "type": "object",
          "required": [
            "role"
          ],
          "properties": {
            "role": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "range": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number"
      }
    }
  },
  "additionalProperties": false
}
